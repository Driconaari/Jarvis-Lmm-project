# Jarvis Configuration - Copy to .env and update values
# This file is NOT checked into git (see .gitignore)

# Ollama Endpoints
OLLAMA_ENDPOINT_1=http://localhost:11434
OLLAMA_ENDPOINT_2=http://localhost:11435

# API Server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False
LOG_LEVEL=INFO

# Optional: Database (for future production use)
DATABASE_URL=sqlite:///./jarvis.db
# DATABASE_URL=postgresql://user:password@localhost:5432/jarvis

# Optional: Authentication
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256

# Optional: CORS  
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Workspace Configuration
GIT_REPO_PATH=./output
MAX_CONTEXT_TOKENS=8000
